{% for group in robots.default_groups %}
    {{- group.user_agent }}
  
    {% for rule in group.rules %}
      {{- rule }}
    {% endfor %}
  
    {%- if group.sitemap != blank -%}
      {{ group.sitemap }}
    {%- endif -%}
  {% endfor %}
  
  # Lanolips AI crawler policy
  # Allow search and discovery crawlers
  
  User-agent: OAI-SearchBot
  Allow: /
  
  User-agent: Claude-SearchBot
  Allow: /
  
  User-agent: PerplexityBot
  Allow: /
  
  User-agent: Applebot
  Allow: /
  
  # Block training and model-improvement crawlers
  
  User-agent: GPTBot
  Disallow: /
  
  User-agent: ClaudeBot
  Disallow: /
  
  User-agent: Google-Extended
  Disallow: /
  
  User-agent: Applebot-Extended
  Disallow: /